# ===================
# Git Diff Stats
# ===================
# Parses numstat from stdin into source vs linguist-generated buckets.
# Sets caller-scoped vars: _sa _sr _sf (source) and _ga _gr _gf (generated)
_gdstat_split() {
  _sa=0 _sr=0 _sf=0
  _ga=0 _gr=0 _gf=0

  local -a na nr nf
  local a r f
  while IFS=$'\t' read -r a r f; do
    [[ -z "$a" ]] && continue
    [[ "$a" == "-" ]] && a=0
    [[ "$r" == "-" ]] && r=0
    na+=("$a"); nr+=("$r"); nf+=("$f")
  done

  (( ${#nf[@]} == 0 )) && return

  local -A gmap
  local line
  while IFS= read -r line; do
    if [[ "$line" == *": linguist-generated: true" || "$line" == *": linguist-generated: set" ]]; then
      gmap[${line%%: linguist-generated:*}]=1
    fi
  done < <(printf '%s\n' "${nf[@]}" | git check-attr linguist-generated --stdin 2>/dev/null)

  local i
  for i in {1..${#nf[@]}}; do
    if (( ${+gmap[${nf[$i]}]} )); then
      (( _ga += na[$i], _gr += nr[$i], _gf++ ))
    else
      (( _sa += na[$i], _sr += nr[$i], _sf++ ))
    fi
  done
}

function gdstat() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    print "Not a git repository"
    return 1
  fi

  local branch fork_point ref
  local -i ahead=0
  local -i _sa _sr _sf _ga _gr _gf

  branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)

  local on_default=false
  [[ "$branch" == "main" || "$branch" == "master" ]] && on_default=true

  local green=$'\033[32m' red=$'\033[31m' cyan=$'\033[36m'
  local dim=$'\033[2m' bold=$'\033[1m' reset=$'\033[0m'
  local sep="${dim}  ─────────────────────────────────────${reset}"

  print ""

  if $on_default; then
    print "  ${bold}${cyan}${branch}${reset}"
  else
    # Find the branch's effective fork point using two signals:
    #   reflog tail  = commit where the branch was originally created
    #   merge-base   = where HEAD diverges from the default branch
    # Use whichever is more recent: after a rebase the merge-base
    # advances past the creation point; for nested branches (created
    # from a non-main branch) the reflog point is more recent.
    local fork_reflog fork_mergebase
    fork_reflog=$(git reflog show --format='%H' "$branch" 2>/dev/null | tail -1)

    for ref in origin/main origin/master main master; do
      if git rev-parse --verify --quiet "$ref" &>/dev/null; then
        fork_mergebase=$(git merge-base HEAD "$ref" 2>/dev/null)
        break
      fi
    done

    if [[ -n "$fork_reflog" && -n "$fork_mergebase" ]]; then
      if git merge-base --is-ancestor "$fork_reflog" "$fork_mergebase" 2>/dev/null; then
        fork_point="$fork_mergebase"
      else
        fork_point="$fork_reflog"
      fi
    else
      fork_point="${fork_reflog:-$fork_mergebase}"
    fi

    [[ -n "$fork_point" ]] && ahead=$(git rev-list --count "${fork_point}..HEAD" 2>/dev/null)

    # Extract parent branch name from reflog creation entry
    local parent_name=""
    local creation_log=$(git reflog show "$branch" --format='%gs' 2>/dev/null | tail -1)
    if [[ "$creation_log" == "branch: Created from "* ]]; then
      parent_name="${creation_log#branch: Created from }"
      [[ "$parent_name" == "HEAD" ]] && parent_name=""
    fi

    local info=""
    if (( ahead > 0 )); then
      info="${ahead} commit"
      (( ahead != 1 )) && info+="s"
      [[ -n "$parent_name" ]] && info+=" from ${parent_name}"
    fi
    if [[ -n "$fork_point" ]]; then
      local base_age=$(git log -1 --format='%cr' "$fork_point" 2>/dev/null)
      if [[ -n "$info" ]]; then
        info+=" (${base_age})"
      else
        info="branched ${base_age}"
      fi
    fi

    if [[ -n "$info" ]]; then
      print "  ${bold}${cyan}${branch}${reset}  ${dim}${info}${reset}"
    else
      print "  ${bold}${cyan}${branch}${reset}"
    fi
  fi

  print "$sep"

  # --- Committed changes (branch only) ---
  local -i csa=0 csr=0 csf=0 cga=0 cgr=0 cgf=0
  if ! $on_default && [[ -n "$fork_point" ]]; then
    _gdstat_split < <(git diff "$fork_point" HEAD --numstat 2>/dev/null)
    csa=$_sa csr=$_sr csf=$_sf cga=$_ga cgr=$_gr cgf=$_gf

    printf "  ${bold}Committed${reset}   ${green}+%-7d${reset}${red}-%-7d${reset}${dim}%d file%s${reset}\n" "$csa" "$csr" "$csf" "$( (( csf != 1 )) && echo s)"
    if (( cgf > 0 )); then
      printf "  ${dim}  generated +%-7d-%-7d%d file%s${reset}\n" "$cga" "$cgr" "$cgf" "$( (( cgf != 1 )) && echo s)"
    fi
  fi

  # --- Working changes (staged + unstaged + untracked) ---
  local work_numstat ufile ulines
  work_numstat=$(git diff HEAD --numstat 2>/dev/null)

  while IFS= read -r ufile; do
    [[ -z "$ufile" ]] && continue
    ulines=$(wc -l < "$ufile" 2>/dev/null)
    ulines=${ulines// /}
    work_numstat+=$'\n'"${ulines}"$'\t'"0"$'\t'"${ufile}"
  done < <(git ls-files --others --exclude-standard 2>/dev/null)

  _gdstat_split <<< "$work_numstat"
  local -i wsa=$_sa wsr=$_sr wsf=$_sf wga=$_ga wgr=$_gr wgf=$_gf

  if (( wsa > 0 || wsr > 0 || wga > 0 || wgr > 0 )); then
    printf "  ${bold}Working${reset}     ${green}+%-7d${reset}${red}-%-7d${reset}${dim}%d file%s${reset}\n" "$wsa" "$wsr" "$wsf" "$( (( wsf != 1 )) && echo s)"
    if (( wgf > 0 )); then
      printf "  ${dim}  generated +%-7d-%-7d%d file%s${reset}\n" "$wga" "$wgr" "$wgf" "$( (( wgf != 1 )) && echo s)"
    fi
  else
    print "  ${dim}Working     clean${reset}"
  fi

  # --- Total (branch only, source-only) ---
  if ! $on_default && [[ -n "$fork_point" ]]; then
    print "$sep"
    printf "  ${bold}Total${reset}       ${green}+%-7d${reset}${red}-%-7d${reset}\n" "$(( csa + wsa ))" "$(( csr + wsr ))"
    if (( cgf + wgf > 0 )); then
      printf "  ${dim}  generated +%-7d-%-7d${reset}\n" "$(( cga + wga ))" "$(( cgr + wgr ))"
    fi
  fi

  print ""
}

